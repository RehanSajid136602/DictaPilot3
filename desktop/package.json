{
    "name": "dictapilot-desktop",
    "version": "1.0.0",
    "description": "DictaPilot Electron Application",
    "private": true,
    "repository": "https://github.com/example/dictapilot",
    "main": "main/dist/index.js",
    "scripts": {
        "start": "electron .",
        "dev": "npm-run-all -p dev:shared dev:main dev:preload dev:backend dev:renderer dev:electron",
        "dev:main": "tsc -b main --watch",
        "dev:preload": "tsc -b preload --watch",
        "dev:backend": "tsc -b backend --watch",
        "dev:renderer": "cd renderer && npm run dev",
        "dev:electron": "wait-on http://localhost:5174 && electronmon .",
        "build": "npm-run-all build:shared build:main build:preload build:backend build:renderer",
        "build:main": "tsc -b main",
        "build:preload": "tsc -b preload",
        "build:backend": "tsc -b backend",
        "build:renderer": "cd renderer && npm run build",
        "package": "npm run build && electron-builder build --win --publish never",
        "test": "jest",
        "lint": "eslint . --ext .ts,.tsx",
        "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
        "dev:shared": "tsc -b shared --watch",
        "build:shared": "tsc -b shared"
    },
    "workspaces": [
        "main",
        "preload",
        "renderer",
        "backend",
        "shared"
    ],
    "devDependencies": {
        "@types/node": "^20.0.0",
        "electron": "^29.1.0",
        "electron-builder": "^24.13.3",
        "electronmon": "^2.0.2",
        "eslint": "^8.57.0",
        "jest": "^29.7.0",
        "npm-run-all": "^4.1.5",
        "prettier": "^3.2.5",
        "typescript": "^5.4.2",
        "wait-on": "^7.2.0"
    },
    "dependencies": {
        "@nut-tree-fork/nut-js": "^4.2.6",
        "dictapilot-desktop-backend": "1.0.0",
        "dictapilot-desktop-shared": "1.0.0",
        "electron-store": "^8.1.0",
        "firebase": "^12.10.0",
        "groq-sdk": "^0.37.0",
        "node-global-key-listener": "^0.3.0"
    },
    "build": {
        "appId": "com.dictapilot.app",
        "productName": "DictaPilot",
        "files": [
            "package.json",
            "assets/**/*",
            "main/dist/**/*",
            "main/package.json",
            "preload/dist/**/*",
            "preload/package.json",
            "renderer/dist/**/*",
            "renderer/package.json",
            "backend/dist/**/*",
            "backend/package.json",
            "shared/dist/**/*",
            "shared/package.json",
            "!dist/**/*",
            "!**/*.tsbuildinfo",
            "!node_modules/@nut-tree-fork/libnut-darwin{,/**/*}",
            "!node_modules/@nut-tree-fork/libnut-linux{,/**/*}",
            "!node_modules/node-global-key-listener/bin/MacKeyServer",
            "!node_modules/node-global-key-listener/bin/X11KeyServer"
        ],
        "win": {
            "target": [
                "nsis",
                "portable"
            ],
            "icon": "assets/icon.ico"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "shortcutName": "DictaPilot"
        },
        "electronLanguages": [
            "en-US"
        ]
    }
}
